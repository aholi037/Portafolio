---
import Layout from "../layouts/Layout.astro";

const proyectos = [
  {
    titulo: "ERP Finca Exportadora de Rosas",
    subtitulo: "Transformación Digital de Extremo a Extremo",
    descripcion:
      "Arquitectura y desarrollo de una plataforma centralizada que digitalizó la cadena de suministro, eliminando procesos manuales críticos y centralizando la operación.",
    logros: [
      {
        icono: "⏱️",
        texto:
          "Reducción del 90% en latencia de información desde campo a oficina central.",
      },
      {
        icono: "📊",
        texto:
          "Visibilidad 100% en tiempo real de inventarios, producción y trazabilidad.",
      },
      {
        icono: "📉",
        texto:
          "Disminución de mermas mediante monitoreo predictivo de temperaturas.",
      },
      {
        icono: "👥",
        texto:
          "Optimización del 60% del personal operativo mediante automatización de cálculos.",
      },
    ],
    tags: ["Laravel", "Vue.js 3", "MySQL", "Arquitectura de Software"],
  },
];

const skills = [
  {
    categoria: "Backend",
    tecnologias: [
      "PHP",
      "Laravel",
      "CodeIgniter",
      "MySQL",
      "API REST",
      "Node.js",
    ],
  },
  {
    categoria: "Frontend",
    tecnologias: [
      "JavaScript (ES6+)",
      "Vue.js",
      "Astro",
      "Tailwind CSS",
      "Bootstrap",
      "Vuetify",
    ],
  },
  {
    categoria: "Infraestructura",
    tecnologias: ["Git", "Docker"],
  },
];
---

<Layout>
  <section
    class="min-h-[90vh] flex flex-col justify-center items-center text-center px-6 relative overflow-hidden py-10"
  >
    <div class="relative mb-7 animate-fade-in-down group">
      <div
        class="absolute -inset-4 bg-gradient-to-r from-blue-600 via-emerald-500 to-blue-600 rounded-full blur-3xl opacity-40 group-hover:opacity-80 group-hover:blur-2xl transition-all duration-1000 ease-in-out"
      >
      </div>

      <div
        class="relative w-40 h-40 md:w-52 md:h-52 rounded-full overflow-hidden border-2 border-white/10 ring-8 ring-white/5 shadow-2xl transition-transform duration-500 group-hover:scale-[1.03]"
      >
        <img
          src="/Foto.jpeg"
          alt="Haroldo Hernández - Analista Programador"
          class="w-full h-full object-cover object-top"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>

    <h1
      class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight text-white animate-fade-in"
    >
      Hola, soy <span
        class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-emerald-400"
        >Haroldo Hernández</span
      >
    </h1>

    <p
      class="text-gray-400 text-lg md:text-xl max-w-2xl mb-10 leading-relaxed animate-fade-in [animation-delay:200ms]"
    >
      Analista Programador enfocado en automatización de procesosy soluciones
      corporativas escalables con
      <span class="text-white font-medium"
        >PHP, Laravel y ecosistemas modernos de JavaScript</span
      >.
    </p>

    <div
      class="flex flex-col sm:flex-row gap-5 animate-fade-in-up [animation-delay:400ms]"
    >
      <a
        href="#proyectos"
        class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-4 rounded-2xl font-bold transition-all hover:shadow-lg hover:shadow-blue-500/25 active:scale-95"
      >
        Ver Casos de Éxito
      </a>
      <a
        href="/CV_Haroldo_Hernández.pdf"
        target="_blank"
        class="bg-white/5 hover:bg-white/10 border border-white/10 text-white px-8 py-4 rounded-2xl font-bold transition-all active:scale-95"
      >
        Ver CV
      </a>
    </div>
  </section>

  <main class="max-w-6xl mx-auto px-6 space-y-32 pb-32">
    <section
      id="sobre-mi"
      class="reveal grid md:grid-cols-3 gap-10 items-center"
    >
      <div class="md:col-span-2 space-y-6">
        <h2 class="text-3xl font-bold text-blue-400 flex items-center gap-3">
          <span class="h-px w-8 bg-blue-500"></span> Sobre mí
        </h2>
        <p class="text-2xl text-gray-200 font-light italic leading-relaxed">
          "Mi enfoque es simple: si un proceso se repite más de tres veces, <span
            class="text-blue-400 font-semibold underline decoration-blue-500/30"
            >debe ser automatizado</span
          >."
        </p>
        <p class="text-gray-400 text-lg leading-relaxed">
          Con más de 3 años de trayectoria, me especializo en transformar
          cuellos de botella operativos en herramientas digitales de alto
          rendimiento. Mi fuerte es la integración de sistemas y la creación de
          reportes predictivos para la toma de decisiones gerenciales.
        </p>
      </div>
      <div
        class="bg-gradient-to-br from-blue-600/10 to-emerald-600/5 p-10 rounded-[3rem] border border-blue-500/20 text-center shadow-inner"
      >
        <span class="text-7xl font-black text-white">+3</span>
        <p
          class="text-blue-400 uppercase tracking-widest text-sm font-bold mt-4"
        >
          Años de Trayectoria
        </p>
      </div>
    </section>

    <section id="proyectos" class="reveal">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-4"
      >
        <div>
          <h2 class="text-4xl font-bold text-white mb-2">
            Impacto y Resultados
          </h2>
          <p class="text-gray-500">
            Soluciones que generan valor real al negocio.
          </p>
        </div>
      </div>

      <div class="space-y-12">
        {
          proyectos.map((p) => (
            <div class="group relative bg-white/[0.02] border border-white/5 rounded-[3rem] p-8 md:p-16 hover:bg-white/[0.04] transition-all duration-500 shadow-2xl overflow-hidden">
              <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 bg-blue-500/5 blur-[80px] rounded-full group-hover:bg-blue-500/10 transition-colors" />

              <div class="relative z-10 grid lg:grid-cols-2 gap-16">
                <div class="space-y-6">
                  <span class="inline-block px-4 py-1 rounded-full bg-blue-500/10 text-blue-400 text-xs font-bold uppercase tracking-widest">
                    Caso de Éxito Corporativo
                  </span>
                  <h3 class="text-4xl font-bold text-white group-hover:text-blue-400 transition-colors">
                    {p.titulo}
                  </h3>
                  <p class="text-gray-400 text-lg leading-relaxed">
                    {p.descripcion}
                  </p>
                  <div class="flex flex-wrap gap-3">
                    {p.tags.map((tag) => (
                      <span class="px-4 py-2 bg-gray-950 text-blue-300 text-xs font-medium rounded-xl border border-white/5 group-hover:border-blue-500/30 transition-all">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-6">
                  {p.logros.map((logro) => (
                    <div class="p-6 rounded-2xl bg-gray-950/50 border border-white/5 hover:border-emerald-500/30 transition-all group/item">
                      <div class="text-3xl mb-4 group-hover/item:scale-110 transition-transform">
                        {logro.icono}
                      </div>
                      <p class="text-gray-300 text-sm leading-snug">
                        {logro.texto}
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section id="experiencia" class="reveal">
      <h2 class="text-3xl font-bold text-white mb-16 flex items-center gap-4">
        Experiencia Profesional <span class="h-px bg-white/10 flex-1"></span>
      </h2>

      <div class="max-w-4xl mx-auto space-y-12">
        <div class="relative pl-12 border-l-2 border-blue-500/30 group">
          <div
            class="absolute w-5 h-5 bg-[#0a0c10] border-2 border-blue-500 rounded-full -left-[11px] top-1 group-hover:scale-125 transition-all shadow-[0_0_15px_rgba(59,130,246,0.5)]"
          >
          </div>
          <div class="mb-2 flex flex-wrap justify-between items-center gap-4">
            <h3
              class="text-2xl font-bold text-white group-hover:text-blue-400 transition-colors"
            >
              Analista Programador
            </h3>
            <span
              class="px-3 py-1 bg-blue-500/10 text-blue-400 text-xs rounded-full border border-blue-500/20"
              >2023 - Actualidad</span
            >
          </div>
          <p class="text-lg text-gray-300 mb-6 font-medium">
            Sistema ERP Corporativo
          </p>
          <ul class="grid md:grid-cols-2 gap-4 text-gray-400 text-sm">
            <li class="flex gap-3">
              <span class="text-blue-500">▹</span> Desarrollo de módulos logísticos
              para trazabilidad internacional de materia prima.
            </li>
            <li class="flex gap-3">
              <span class="text-blue-500">▹</span> Implementación de sistemas de control
              de calidad en tiempo real para postcosecha.
            </li>
            <li class="flex gap-3">
              <span class="text-blue-500">▹</span> Modelado de BD escalables para
              registros masivos de producción diaria.
            </li>
            <li class="flex gap-3">
              <span class="text-blue-500">▹</span> Optimización de flujos administrativos
              mediante interfaces reactivas en Vue.js.
            </li>
            <li class="flex gap-3">
              <span class="text-blue-500">▹</span> Sistema adaptado al giro del negocio,
              hecho a la medida y adaptado a los procesos internos, con una curva
              de aprendizaje mínima para el equipo.
            </li>
          </ul>
        </div>

        <div class="relative pl-12 border-l-2 border-gray-800 group">
          <div
            class="absolute w-5 h-5 bg-[#0a0c10] border-2 border-gray-800 rounded-full -left-[11px] top-1 group-hover:border-emerald-500 transition-all"
          >
          </div>
          <div class="mb-2 flex flex-wrap justify-between items-center gap-4">
            <h3
              class="text-2xl font-bold text-white group-hover:text-emerald-400 transition-colors"
            >
              Desarrollador de Software
            </h3>
            <span
              class="px-3 py-1 bg-gray-800 text-gray-400 text-xs rounded-full"
              >2021 - 2022</span
            >
          </div>
          <p class="text-lg text-gray-300 mb-6 font-medium">
            Gestión Farmacéutica Centralizada
          </p>
          <p class="text-gray-400 text-sm leading-relaxed mb-4 max-w-2xl">
            Lideré la construcción de una plataforma para el control de stock
            farmacéutico, resolviendo la sincronización crítica de inventarios
            entre múltiples puntos de venta y bodega central.
          </p>
        </div>
      </div>
    </section>

    <section id="tecnologias" class="reveal">
      <h2 class="text-3xl font-bold text-white mb-16">Stack Tecnológico</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {
          skills.map((grupo) => (
            <div class="p-8 rounded-[2rem] bg-white/[0.02] border border-white/5 hover:border-blue-500/40 transition-all">
              <h3 class="text-blue-400 font-bold mb-6 uppercase text-xs tracking-widest">
                {grupo.categoria}
              </h3>
              <div class="flex flex-wrap gap-2">
                {grupo.tecnologias.map((tech) => (
                  <span class="px-4 py-2 bg-gray-950 rounded-xl text-gray-300 text-xs border border-white/5 hover:text-white transition-colors cursor-default">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <div
        class="mt-12 flex items-center gap-6 p-8 bg-blue-600/5 border border-blue-500/10 rounded-[2rem]"
      >
        <div
          class="hidden sm:block p-4 bg-blue-500/10 rounded-2xl text-blue-400 text-3xl"
        >
          🏆
        </div>
        <div>
          <h4 class="text-white font-bold text-lg">Curso Avanzado de Vue.js</h4>
          <p class="text-gray-400 text-sm mb-2">Platzi Certification • 2023</p>
          <a
            href="https://drive.google.com/file/d/1nUlihi9X9zlkYsolQ9LKdBEh_gQRuPTZ/view"
            target="_blank"
            class="text-blue-400 text-sm hover:underline font-medium"
            >Verificar Credencial →</a
          >
        </div>
      </div>
    </section>

    <section id="contacto" class="reveal py-20">
      <div
        class="relative bg-gradient-to-b from-grey-600 to-blue-800 rounded-[3rem] p-10 md:p-20 overflow-hidden shadow-2xl shadow-blue-500/20 text-center md:text-left"
      >
        <div class="relative z-10 grid md:grid-cols-2 gap-16 items-center">
          <div class="space-y-6">
            <h2 class="text-5xl font-black text-white leading-tight">
              ¿Quieres hablar?
            </h2>
            <p class="text-blue-100 text-lg opacity-90">Envíame un mensaje.</p>
            <div class="flex flex-col gap-4">
              <a
                href="mailto:aholiab2000castro@gmail.com"
                class="flex items-center gap-4 text-white hover:translate-x-2 transition-transform"
              >
                <span class="bg-white/20 p-3 rounded-xl">📧</span> aholiab2000castro@gmail.com
              </a>
              <a
                href="https://linkedin.com/in/aholiab-castro-a47251202"
                target="_blank"
                class="flex items-center gap-4 text-white hover:translate-x-2 transition-transform"
              >
                <span class="bg-white/20 p-3 rounded-xl">🔗</span> LinkedIn: Aholiab
                Castro
              </a>
            </div>
          </div>

          <form
            action="https://formspree.io/f/mqeylvzl"
            method="POST"
            class="bg-white p-8 rounded-[2rem] space-y-4 shadow-xl"
          >
            <input
              type="text"
              name="name"
              required
              placeholder="Nombre"
              class="w-full px-6 py-4 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-500 text-gray-900"
            />
            <input
              type="email"
              name="email"
              required
              placeholder="Tu correo"
              class="w-full px-6 py-4 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-500 text-gray-900"
            />
            <textarea
              name="message"
              rows="4"
              required
              placeholder="¿En qué puedo ayudarte?"
              class="w-full px-6 py-4 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-500 text-gray-900 resize-none"
            ></textarea>
            <button
              type="submit"
              class="w-full bg-blue-600 text-white font-bold py-4 rounded-xl hover:bg-gray-900 transition-colors"
              >Enviar Mensaje</button
            >
          </form>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Animaciones integradas con el motor de Astro */
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .animate-fade-in-down {
    animation: fadeInDown 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const setupAnimations = () => {
    const reveals = document.querySelectorAll(".reveal");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
          }
        });
      },
      { threshold: 0.1 },
    );

    reveals.forEach((el) => observer.observe(el));
  };

  // Inicializar
  setupAnimations();
  document.addEventListener("astro:after-swap", setupAnimations);

  // Lógica del Formulario
  const setupForm = () => {
    const form = document.querySelector("form");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const target = e.target as HTMLFormElement;
      const btn = target.querySelector("button");
      if (btn) {
        btn.disabled = true;
        btn.innerText = "Enviando...";
      }

      try {
        const response = await fetch(target.action, {
          method: "POST",
          body: new FormData(target),
          headers: { Accept: "application/json" },
        });
        if (response.ok) {
          alert("¡Mensaje recibido! Te contactaré pronto.");
          target.reset();
        }
      } catch {
        alert("Hubo un error. Por favor usa el email directo.");
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.innerText = "Enviar Mensaje";
        }
      }
    });
  };

  setupForm();
  document.addEventListener("astro:after-swap", setupForm);
</script>
