---
// src/layouts/Layout.astro
import "../styles/global.css"; 
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Haroldo Hernández | Analista Programador</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#0a0c10] text-gray-200 font-sans antialiased">
    <nav class="fixed top-0 w-full bg-[#0a0c10]/80 backdrop-blur-md border-b border-gray-800/50 z-50">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="#" class="font-bold text-2xl tracking-tighter text-white hover:text-blue-400 transition-colors">
          <span class="text-blue-500">Haroldo</span>
        </a>

        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-400">
          <a href="#sobre-mi" class="hover:text-white transition-colors">Sobre mí</a>
          <a href="#proyectos" class="hover:text-white transition-colors">Impacto</a>
          <a href="#experiencia" class="hover:text-white transition-colors">Experiencia</a>
          <a href="#tecnologias" class="hover:text-white transition-colors">Tecnologías</a>
          
          <a 
            href="#contacto" 
            class="bg-blue-600/10 text-blue-400 border border-blue-500/20 px-4 py-2 rounded-lg hover:bg-blue-600 hover:text-white transition-all shadow-lg shadow-blue-500/5"
          >
            Contáctame
          </a>
        </div>

        <div class="md:hidden text-gray-400 text-xs border border-gray-800 px-2 py-1 rounded">
          Menu
        </div>
      </div>
    </nav>

    <div class="pt-20">
      <slot />
    </div>

    <footer class="border-t border-gray-800/50 py-10 text-center text-gray-500 text-sm">
      <p>© {new Date().getFullYear()} Haroldo Hernández — Analista Programador</p>
    </footer>

    <style is:global>
      :root {
        --accent-blue: 59, 130, 246;
      }
      
      html {
        /* FIX: Esto evita que el navbar tape los títulos al hacer scroll */
        scroll-padding-top: 100px;
        font-family: 'Inter', sans-serif;
      }

      body {
        /* Fondo con un ligero gradiente para que no sea un negro plano */
        background-image: 
          radial-gradient(circle at 50% -20%, rgba(59, 130, 246, 0.05), transparent),
          radial-gradient(circle at 0% 100%, rgba(16, 185, 129, 0.02), transparent);
      }

      /* Personalización de la barra de scroll */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #0a0c10;
      }
      ::-webkit-scrollbar-thumb {
        background: #1f2937;
        border-radius: 10px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3b82f6;
      }
    </style>
  </body>
</html>